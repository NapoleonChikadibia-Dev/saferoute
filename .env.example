# ─────────────────────────────────────────────────────────────────
# SafeRoute — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. Add it to .gitignore immediately.
# ─────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite in development)
# For production PostgreSQL:
# DATABASE_URL=postgres://user:password@host:5432/saferoute_db
DATABASE_URL=

# News API — get free key at https://newsapi.org
NEWS_API_KEY=your-newsapi-key-here

# Email (for password reset)
# Development: leave EMAIL_BACKEND as console backend (prints to terminal)
# Production: switch to smtp
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SafeRoute <noreply@saferoute.app>
